# ManaClaw Environment Variables
# Copy to .env and fill in your values.

# Provider credentials (injected into containers via credential manager)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Ollama (default, no API key needed for local)
OLLAMA_BASE_URL=http://localhost:11434

# Database (override config.toml)
# MANACLAW_DB_PASSWORD=

# Server
# MANACLAW_API_KEY=

# Memory
# MEM0_API_KEY=
