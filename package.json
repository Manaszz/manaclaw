{
  "name": "manaclaw",
  "version": "0.1.0",
  "description": "Lightweight, provider-agnostic AI assistant with container isolation, pluggable memory, and built-in HTTP/CLI/Web channels",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "manaclaw": "dist/bin/manaclaw.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/src/index.js",
    "cli": "tsx bin/manaclaw.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ bin/",
    "format": "prettier --write \"src/**/*.ts\" \"bin/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "assistant",
    "agent",
    "opencode",
    "container",
    "mcp",
    "openai-compatible"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "commander": "^13.0.0",
    "cron-parser": "^5.0.0",
    "fastify": "^5.0.0",
    "@fastify/cors": "^10.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "smol-toml": "^1.0.0",
    "yaml": "^2.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
